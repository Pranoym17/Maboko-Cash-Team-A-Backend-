PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=maboko_cash
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true

JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=1d
ADMIN_SIGNUP_PASSCODE=temporary_admin_passcode
FRONTEND_BASE_URL=http://localhost:3001
SWAGGER_ENABLED=true
SWAGGER_BASIC_AUTH=
WS_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
MOBILE_MONEY_WEBHOOK_SECRET=replace_with_a_long_random_secret
MOBILE_MONEY_WEBHOOK_TOLERANCE_MS=300000
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA=

# Google Cloud Translation API
GCP_PROJECT_ID=your-google-cloud-project-id
GCP_KEY_FILENAME=/absolute/path/to/your/service-account.json
